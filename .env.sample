SHOPEE_REGION=sg
SHOPEE_SELLER_URL=https://seller.shopee.sg/portal/product/new
SHOPEE_EMAIL=
SHOPEE_PASSWORD=

# playwright | paapi | manual-json
# paapi/manual-json are safer for production. playwright is MVP fallback only.
AMAZON_SOURCE=manual-json
AMAZON_MANUAL_JSON=./data/manual-products.sample.json

# en | zh
TARGET_LANGUAGE=en

DEFAULT_STOCK=10

# Target profit margin on the final selling price.
# Example: cost 100 and margin 20% => sell at 125, profit 25 / 125 = 20%.
TARGET_PROFIT_MARGIN_PERCENT=20

# Optional Shopee/payment/other fee percentage on final selling price.
# Example: margin 20% and fee 10% => cost / (1 - 0.20 - 0.10).
PLATFORM_FEE_PERCENT=0

# Legacy fallback. Used only if TARGET_PROFIT_MARGIN_PERCENT is empty.
PRICE_MARKUP_PERCENT=
SHOPEE_UPLOAD_IMAGES=true

# Keeps Shopee login session between runs.
USER_DATA_DIR=./.user-data/shopee

# Optional Amazon Product Advertising API placeholders.
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=
AMAZON_PAAPI_HOST=webservices.amazon.com
AMAZON_PAAPI_REGION=us-east-1

# Set to 1 if you need to inspect each browser step slowly.
HEADFUL=true
SLOW_MO_MS=150

