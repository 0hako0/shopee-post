{
  "restrictedKeywords": [
    {
      "name": "Food and supplements",
      "keywords": ["food", "supplement", "vitamin", "snack", "tea", "coffee"],
      "warning": "Food and supplements may require ingredient, expiry, import, and labeling checks."
    },
    {
      "name": "Cosmetics",
      "keywords": ["cosmetic", "skin care", "lotion", "cream"],
      "warning": "Cosmetics may require ingredient, claim, import, and sale compliance checks."
    },
    {
      "name": "Medicine",
      "keywords": ["medicine", "drug", "pharmaceutical"],
      "warning": "Medicine should usually be excluded from automated listing. Check regulations first."
    },
    {
      "name": "Electronics",
      "keywords": ["battery", "charger", "adapter", "electronics"],
      "warning": "Electronics may require certification, voltage, plug, and battery shipping checks."
    }
  ],
  "attributeSynonyms": {
    "brand": ["brand", "manufacturer", "maker"],
    "model": ["model", "model number", "item model number"],
    "material": ["material", "materials"],
    "ingredients": ["ingredients", "ingredient"],
    "size": ["size", "dimensions", "package dimensions"],
    "weight": ["weight", "item weight", "package weight"],
    "color": ["color", "colour"],
    "countryOfOrigin": ["country of origin", "origin"],
    "expiryDate": ["expiry", "expiration", "best before"],
    "capacity": ["capacity", "volume", "volume capacity"]
  },
  "categoryRules": [
    {
      "matchKeywords": ["cosmetic", "skin care"],
      "requiredAttributes": ["brand", "ingredients", "countryOfOrigin", "expiryDate"]
    },
    {
      "matchKeywords": ["electronics", "battery", "charger"],
      "requiredAttributes": ["brand", "model", "weight"]
    }
  ],
  "specificationDefaults": [
    {
      "matchCategoryKeywords": ["Water Bottles & Accessories", "Travel Size Bottles & Containers", "Cups, Mugs & Glasses"],
      "defaults": {
        "Sports Product": "No",
        "pack type": "Single",
        "Food Storage Product Type": "Bottle",
        "Custom Product": "No",
        "Warranty Duration": "No Warranty",
        "Warranty Type": "No Warranty",
        "Storage Feature": "With Lid"
      }
    }
  ]
}
