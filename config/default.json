{
  "shopee": {
    "region": "sg",
    "sellerUrl": "https://seller.shopee.sg/portal/product/new",
    "userDataDir": "./.user-data/shopee",
    "uploadImages": true,
    "maxImages": 3
  },
  "amazon": {
    "source": "manual-json",
    "manualJsonPath": "./data/manual-products.sample.json",
    "slowDownMs": 2500
