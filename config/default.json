  "listing": {
    "targetLanguage": "en",
    "defaultStock": 10,
    "targetProfitMarginPercent": 20,
    "platformFeePercent": 0,
    "currency": "SGD"
  },
  "rulesPath": "./config/category-rules.sample.json"
}

